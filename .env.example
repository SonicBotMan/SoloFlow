# SoloFlow 环境变量配置

# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：使用国内模型
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 通义千问
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/              # 智谱AI

# 数据库路径
DATABASE_PATH=data/soloflow.db

# Web 配置
HOST=0.0.0.0
PORT=8000

# Agent 配置目录
AGENTS_DIR=soloflow/agents

# 日志级别
LOG_LEVEL=INFO
